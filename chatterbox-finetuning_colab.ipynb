    "\n",
    "# Check if preprocessing should run (handles True, False, and 'auto')\n",
    "preprocess_val = None\n",
    "preprocess_match = re.search(r\"preprocess\\s*=\\s*['\"]?([^'\"\\s]+)['\"]?\", config_content)\n",
    "if preprocess_match:\n",
    "    preprocess_val = preprocess_match.group(1).strip()\n",
    "\n",
    "# Determine if we should run preprocessing\n",
    "should_run_preprocess = False\n",
    "if preprocess_val == 'True':\n",
    "    should_run_preprocess = True\n",
    "elif preprocess_val == 'auto':\n",
    "    # Auto mode: check if preprocessed_dir exists and has matching file counts\n",
    "    import os, glob\n",
    "    wav_match = re.search(r\"wav_dir\\s*=\\s*['\\\"]([^'\\\"]+)['\\\"]\", config_content)\n",
    "    preprocess_dir_match = re.search(r\"preprocessed_dir\\s*=\\s*['\\\"]([^'\\\"]+)['\\\"]\", config_content)\n",
    "    if wav_match and preprocess_dir_match:\n",
    "        wav_dir = wav_match.group(1)\n",
    "        preprocessed_dir = preprocess_dir_match.group(1)\n",
    "        if not os.path.exists(preprocessed_dir):\n",
    "            should_run_preprocess = True\n",
    "        else:\n",
    "            wav_count = len(glob.glob(os.path.join(wav_dir, '*.wav')))\n",
    "            pt_count = len(glob.glob(os.path.join(preprocessed_dir, '*.pt')))\n",
    "            if wav_count != pt_count:\n",
    "                should_run_preprocess = True\n",
    "else:\n",
    "    should_run_preprocess = True  # Default to running if not found\n",
    "\n",
    "if should_run_preprocess:\n",
    "    print(\"\\n\u23f3 Starting preprocessing (this may take several minutes)...\")\n",
    "    !python train.py\n",
    "    print(\"\\n\u2705 Preprocessing completed!\")\n",
    "    print(\"\\n\" + \"=\"*50)\n",
    "    print(\"\ud83c\udfcb\ufe0f Starting training...\")\n",
    "    print(\"=\"*50)\n",
    "    print(\"Training progress and audio samples will be displayed below.\")\n",
    "    print(\"Press Ctrl+C to stop training early.\")\n",
    "    !python train.py\n",
    "else:\n",
    "    print(\"\\n\u23f3 Skipping preprocessing (preprocess=False or auto-detected as complete)\")\n",
    "    print(\"\\n\ud83c\udfcb\ufe0f Starting training...\")\n",
    "    print(\"=\"*50)\n",
    "    print(\"Training progress and audio samples will be displayed below.\")\n",
    "    print(\"Press Ctrl+C to stop training early.\")\n",
    "    !python train.py\n",
    "\n",
    "print(\"\\n\u2705 Training completed!\")\n",
    "print(\"Check the chatterbox_output/ directory for your trained model.\")"
   ]
