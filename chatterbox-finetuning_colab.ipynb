    "        config_content = re.sub(r'lora_alpha:\\s*int\\s*=\\s*.*', f'lora_alpha: int = {lora_alpha_value}', config_content)\n",
    "        config_content = re.sub(r'save_steps:\\s*int\\s*=\\s*.*', f'save_steps: int = {save_steps_value}', config_content)\n",
    "        config_content = re.sub(r'save_total_limit:\\s*int\\s*=\\s*.*', f'save_total_limit: int = {save_total_limit_value}', config_content)\n",
    "        config_content = re.sub(r'dataloader_num_workers:\\s*int\\s*=\\s*.*', f'dataloader_num_workers: int = {dataloader_workers_value}', config_content)\n",
    "        config_content = re.sub(r'max_text_len:\\s*int\\s*=\\s*.*', f'max_text_len: int = {max_text_len_value}', config_content)\n",
    "        config_content = re.sub(r'max_speech_len:\\s*int\\s*=\\s*.*', f'max_speech_len: int = {max_speech_len_value}', config_content)\n",
    "        config_content = re.sub(r'prompt_duration:\\s*float\\s*=\\s*.*', f'prompt_duration: float = {prompt_duration_value}', config_content)\n",
