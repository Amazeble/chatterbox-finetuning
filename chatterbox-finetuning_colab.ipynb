    "\n",
    "dataloader_workers_widget = widgets.IntSlider(\n",
    "    value=current_dataloader_workers,\n",
    "    min=0,\n",
    "    max=16,\n",
    "    step=1,\n",
    "    description='Workers',\n",
    "    disabled=False,\n",
    "    tooltip='Number of dataloader workers'\n",
    ")\n",
    "\n",
    "vocab_size_widget = widgets.IntText(\n",
    "    value=current_vocab,\n",
    "    description='Vocab Size',\n",
    "    disabled=False,\n",
    "    tooltip='Must match tokenizer.json (update after setup.py if Turbo)'\n",
    ")\n",
    "\n",
    "lora_r_widget = widgets.IntSlider(\n",
    "    value=current_lora_r,\n",
    "    min=8,\n",
    "    max=256,\n",
    "    step=8,\n",
    "    description='LoRA R',\n",
    "    disabled=False,\n",
    "    tooltip='LoRA rank dimension'\n",
    ")\n",
    "\n",
    "lora_alpha_widget = widgets.IntSlider(\n",
    "    value=current_lora_alpha,\n",
    "    min=16,\n",
    "    max=512,\n",
    "    step=16,\n",
    "    description='LoRA Alpha',\n",
    "    disabled=False,\n",
    "    tooltip='LoRA alpha scaling factor'\n",
    ")\n",
    "\n",
    "max_text_len_widget = widgets.IntSlider(\n",
    "    value=current_max_text_len,\n",
    "    min=64,\n",
    "    max=512,\n",
    "    step=32,\n",
    "    description='Max Text Len',\n",
    "    disabled=False,\n",
    "    tooltip='Maximum text sequence length'\n",
    ")\n",
    "\n",
    "max_speech_len_widget = widgets.IntSlider(\n",
    "    value=current_max_speech_len,\n",
    "    min=200,\n",
    "    max=2000,\n",
    "    step=50,\n",
    "    description='Max Speech Len',\n",
    "    disabled=False,\n",
    "    tooltip='Maximum speech sequence length'\n",
    ")\n",
    "\n",
    "prompt_duration_widget = widgets.FloatSlider(\n",
    "    value=current_prompt_duration,\n",
    "    min=1.0,\n",
    "    max=10.0,\n",
    "    step=0.5,\n",
    "    description='Prompt Dur',\n",
    "    disabled=False,\n",
    "    tooltip='Duration for reference prompt (seconds)'\n",
    ")\n",
    "\n",
    "start_token_widget = widgets.IntText(\n",
    "    value=current_start_token,\n",
    "    description='Start Token',\n",
