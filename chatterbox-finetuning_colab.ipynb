    "display(batch_size_widget)\n",
    "display(grad_accum_widget)\n",
    "display(learning_rate_widget)\n",
    "display(num_epochs_widget)\n",
    "display(Markdown(\"**Checkpoint Settings:**\"))\n",
    "display(save_steps_widget)\n",
    "display(save_total_limit_widget)\n",
    "display(dataloader_workers_widget)\n",
    "display(Markdown(\"**Model Constraints:**\"))\n",
    "display(max_text_len_widget)\n",
    "display(max_speech_len_widget)\n",
    "display(prompt_duration_widget)\n",
    "display(start_token_widget)\n",
    "display(stop_token_widget)\n",
    "display(Markdown(\"**LoRA Settings:**\"))\n",
    "display(lora_r_widget)\n",
    "display(lora_alpha_widget)\n",
    "display(vocab_size_widget)\n",
    "\n",
    "print(\"\\n\" + \"=\"*50)\n",
    "print(\"Click the button below to apply your settings to config.py\")\n",
    "print(\"=\"*50)\n",
    "\n",
    "# Create apply button\n",
    "apply_button = widgets.Button(\n",
    "    description='Apply Settings to config.py',\n",
    "    button_style='success',\n",
    "    tooltip='Click to apply the widget settings to src/config.py'\n",
    ")\n",
    "\n",
    "output = widgets.Output()\n",
    "\n",
    "def on_apply_clicked(b):\n",
    "    with output:\n",
    "        clear_output()\n",
    "        # Get widget values\n",
    "        turbo_value = \"True\" if is_turbo_widget.value else \"False\"\n",
    "        lora_value = \"True\" if is_lora_widget.value else \"False\"\n",
    "        ljspeech_value = \"True\" if ljspeech_widget.value else \"False\"\n",
    "        json_value = \"True\" if json_format_widget.value else \"False\"\n",
    "        preprocess_value = \"'\" + str(preprocess_widget.value) + \"'\" if preprocess_widget.value == 'auto' else (\"True\" if preprocess_widget.value else \"False\")\n",
    "        batch_value = str(batch_size_widget.value)\n",
    "        grad_accum_value = str(grad_accum_widget.value)\n",
    "        lr_value = str(learning_rate_widget.value)\n",
    "        epochs_value = str(num_epochs_widget.value)\n",
    "        vocab_value = str(vocab_size_widget.value)\n",
    "        lora_r_value = str(lora_r_widget.value)\n",
    "        lora_alpha_value = str(lora_alpha_widget.value)\n",
    "        save_steps_value = str(save_steps_widget.value)\n",
    "        save_total_limit_value = str(save_total_limit_widget.value)\n",
    "        dataloader_workers_value = str(dataloader_workers_widget.value)\n",
    "        max_text_len_value = str(max_text_len_widget.value)\n",
    "        max_speech_len_value = str(max_speech_len_widget.value)\n",
    "        prompt_duration_value = str(prompt_duration_widget.value)\n",
    "        start_token_value = str(start_token_widget.value)\n",
    "        stop_token_value = str(stop_token_widget.value)\n",
    "        \n",
    "        # Read current config\n",
    "        with open('src/config.py', 'r') as f:\n",
    "            config_content = f.read()\n",
    "        \n",
    "        # Update all settings\n",
    "        config_content = re.sub(r'is_turbo:\\s*bool\\s*=\\s*.*', f'is_turbo: bool = {turbo_value}', config_content)\n",
    "        config_content = re.sub(r'is_lora:\\s*bool\\s*=\\s*.*', f'is_lora: bool = {lora_value}', config_content)\n",
